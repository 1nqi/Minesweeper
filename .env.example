# --- Общее ---
SECRET_KEY=change-me-to-a-long-random-string
# Альтернатива SECRET_KEY (удобно в Railway):
# DJANGO_SECRET_KEY=

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# На Railway для CSRF при ALLOWED_HOSTS=* обычно хватает RAILWAY_PUBLIC_DOMAIN (задаёт платформа).
# Резерв: PUBLIC_HOST=your-app.up.railway.app или CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

SITE_ID=1
LANGUAGE_CODE=ru
TIME_ZONE=UTC

# --- База данных ---
# Вариант A (рекомендуется на Railway): добавьте плагин PostgreSQL и привяжите его к сервису —
# переменная DATABASE_URL появится сама. Локально можно скопировать её из Railway (вкладка Postgres → Connect).
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
#
# SSL: для облачного Postgres обычно True; локальный Postgres без SSL — DATABASE_SSL_REQUIRE=False
DATABASE_SSL_REQUIRE=True

# Вариант B: отдельные DB_* (если DATABASE_URL нет — Django соберёт postgres:// сам)
# DB_NAME=minesweeper
# DB_USER=minesweeper
# DB_PASSWORD=ваш_пароль
# DB_HOST=localhost
# DB_PORT=5432

# Вариант C: SQLite (по умолчанию локально)
USE_POSTGRES=False
SQLITE_PATH=db.sqlite3

# Разовый перенос SQLite → PostgreSQL (см. README): при PostgreSQL в default укажите путь к старому .sqlite3
# COPY_FROM_SQLITE_PATH=db.sqlite3

# Вариант D: Postgres без URL, только POSTGRES_* + USE_POSTGRES=True
# USE_POSTGRES=True
POSTGRES_DB=minesweeper
POSTGRES_USER=minesweeper
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# --- Stripe ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_YEARLY=
PRO_TEST_BUTTON=True

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_HINT_EXPLAIN=True

# --- Продакшен-логи / HTTPS (часто только на сервере) ---
SECURE_SSL_REDIRECT=True
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
