# Скопируй в .env и заполни значения: copy .env.example .env

# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Доверенные источники для CSRF (через запятую; для продакшена с HTTPS)
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Язык/время по умолчанию (опционально)
# LANGUAGE_CODE=ru
# TIME_ZONE=UTC

# Django Sites (allauth)
SITE_ID=1

# --- База данных ---
# SQLite (по умолчанию): путь от корня проекта или абсолютный
SQLITE_PATH=db.sqlite3

# PostgreSQL: выстави USE_POSTGRES=True и заполни поля ниже
# Нужен пакет: psycopg2-binary
# USE_POSTGRES=False
# POSTGRES_DB=minesweeper
# POSTGRES_USER=minesweeper
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Google OAuth (django-allauth) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# --- Stripe (Pro membership) ---
# Тестовые ключи из https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Разрешить «DEV: активировать Pro бесплатно» (только для разработки!)
PRO_TEST_BUTTON=True
